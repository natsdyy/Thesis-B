{
  "name": "thesis-b",
  "version": "1.0.0",
  "description": "Full-stack application with Vue.js frontend and Express.js backend",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && nodemon server.js",
    "start": "cd backend && node server.js",
    "build": "cd frontend && rm -rf node_modules package-lock.json && npm cache clean --force && npm install && npm run build",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install && echo 'Backend dependencies installed' && ls -la node_modules/express",
    "install:backend": "cd backend && npm install"
  },
  "keywords": [
    "vue",
    "express",
    "fullstack"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2",
    "daisyui": "^5.0.50",
    "prettier": "^3.6.2",
    "nodemon": "^3.1.10"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "lucide-vue-next": "^0.539.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "4.19.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.64.0",
    "pg": "^8.16.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "engines": {
    "node": "18.20.5",
    "npm": ">=8.0.0"
  }
}
