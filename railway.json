{
  "$schema": "https://railway.app/railway.schema.json",
  "_comment": "Updated to serve built frontend files and fix API connectivity - v2",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && npm run build",
    "watchPatterns": [
      "frontend/src/**/*",
      "frontend/components/**/*",
      "frontend/views/**/*",
      "backend/routes/**/*",
      "backend/models/**/*",
      "backend/config/**/*"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "cd backend && npm start",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "8080",
        "BACKEND_PORT": "5000"
      }
    }
  }
}
