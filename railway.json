{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "npm install && cd frontend && npm install && npm run build",
    "watchPatterns": [
      "frontend/src/**/*",
      "frontend/components/**/*",
      "frontend/views/**/*",
      "backend/routes/**/*",
      "backend/models/**/*",
      "backend/config/**/*"
    ]
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "startCommand": "npm run dev",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "PORT": "3000"
      }
    }
  }
}
