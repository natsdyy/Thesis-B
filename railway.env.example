# Railway Environment Variables
# Copy this file to .env.railway and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/railway

# Node Environment
NODE_ENV=production
RAILWAY_ENVIRONMENT=production

# Server Configuration
PORT=5000

# CORS Configuration (for production)
CORS_ORIGIN=https://your-frontend-domain.railway.app

# JWT Secret (generate a strong secret for production)
JWT_SECRET=your-super-secret-jwt-key-here

# Email Configuration (Choose ONE method)

# Method 1: SendGrid (Recommended for Railway)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Method 2: SMTP (if using external SMTP service)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailcountrysidesteakhouse@gmail.com
SMTP_PASS=your-gmail-app-password

# Method 3: Railway-compatible SMTP (if using services like Mailgun SMTP)
RAILWAY_SMTP_HOST=smtp.mailgun.org
RAILWAY_SMTP_PORT=2525
RAILWAY_SMTP_USER=your-mailgun-user
RAILWAY_SMTP_PASS=your-mailgun-pass

# OpenAI Configuration (if you want to use it in production)
OPENAI_API_KEY=your-openai-api-key-here

# Railway-specific variables
RAILWAY_STATIC_URL=https://your-frontend-domain.railway.app
RAILWAY_SERVICE_NAME=thesis-b-backend
                        